{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"baseUrl": ".",
		"paths": {
			"@openwriter/extension-types": ["../openwriter-extension-types/dist/index.d.ts"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules"]
}
