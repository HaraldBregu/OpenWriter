{
	"name": "@openwriter/extension-sdk",
	"version": "0.1.0",
	"description": "OpenWriter SDK for building extensions with typed host APIs, doc panels, and framework-backed HTML views.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"package.json"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"prepack": "npm run build"
	},
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@openwriter/extension-types": "0.1.0"
	},
	"devDependencies": {
		"typescript": "^5.8.3"
	}
}
